<?xml version="1.0" encoding="utf-8"?>
<!-- dash_void fill + thin bottom border in dash_grid -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <color android:color="@color/dash_void"/>
    </item>
    <item
        android:left="-1000dp"
        android:right="-1000dp"
        android:top="-1000dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/dash_grid"/>
        </shape>
    </item>
</layer-list>
