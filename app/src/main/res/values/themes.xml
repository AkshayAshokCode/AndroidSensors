<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MetalDetector" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/dash_void</item>
        <item name="colorPrimaryVariant">@color/dash_void</item>
        <item name="colorOnPrimary">@color/toolbar_text</item>

        <!-- Status bar matches the futuristic void background -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/dash_void</item>

        <item name="android:navigationBarColor" tools:targetApi="l">@color/dash_void</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="l">false</item>
        <!-- Prevents white flash during Z-axis shared axis transitions -->
        <item name="android:windowBackground">@color/dash_void</item>
    </style>

    <!-- Nav drawer item text: monospace + letter-spaced -->
    <style name="NavDrawerItem" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Futuristic toolbar title: bold + letter-spaced -->
    <style name="DashToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>